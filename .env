# ============================================================
# DLRG Wachplan-Generator – Environment-Vorlage
#
#   cp .env.example .env   und Werte eintragen.
#   .env ist gitignored und wird von docker-compose (env_file) sowie
#   vom lokalen `node server.js` (dotenv) geladen.
# ============================================================

# ── Laufzeit ────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
ADMIN_PORT=3001

# ── Verschlüsselung & Session (PFLICHT) ─────────────────────
# Neue Werte erzeugen mit:
#   MASTER_SECRET  : openssl rand -base64 32   (min. 32 Zeichen)
#   SALT           : openssl rand -base64 16   (min. 16 Zeichen)
#   SESSION_SECRET : openssl rand -base64 32   (min. 16 Zeichen)
#
# ⚠ ACHTUNG: MASTER_SECRET und SALT gehen in die Plan-Verschlüsselung ein
#   (db/crypto.js → deriveKey). Werden sie nachträglich geändert, sind ALLE
#   bereits gespeicherten Pläne nicht mehr entschlüsselbar. Vor einer Rotation
#   die Pläne mit dem alten Key ent- und mit dem neuen neu verschlüsseln.
#   SESSION_SECRET kann gefahrlos rotiert werden (loggt nur alle Nutzer aus).
MASTER_SECRET=ERSETZE_MICH_openssl_rand_base64_32
SALT=ERSETZE_MICH_openssl_rand_base64_16
SESSION_SECRET=ERSETZE_MICH_openssl_rand_base64_32

# ── Session-Cookie HTTPS/TLS (DSGVO Art. 32) ────────────────
# COOKIE_SECURE=true  – Cookie nur über HTTPS übertragen (GDPR-konform)
# Default: true in NODE_ENV=production, false sonst (lokale HTTP-Entwicklung).
# Bei TLS-Reverse-Proxy (z.B. Synology/QNAP NAS) → setzen.
# COOKIE_SECURE=true

# ── Erst-Admin (optional) ───────────────────────────────────
# Legt beim ersten Start einen Admin-User an (db/init.js). Danach entfernbar.
# Alternativ ohne diese Variablen: Admin via POST /api/auth/init anlegen.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ERSETZE_MICH_starkes_passwort

# ── Selbstregistrierung (optional) ───────────────────────────
# REGISTRATION_MODE: disabled (default) | open | code
#   - disabled: Keine Selbstregistrierung, UI ausgeblendet, Endpoint 403
#   - open: Jeder kann sich registrieren (nur für vertrauenswürdige LAN/VPN)
#   - code: Registrierung nur mit gültigem REGISTRATION_CODE
#
# Wenn REGISTRATION_MODE=code, REGISTRATION_CODE setzen (beliebige String):
# REGISTRATION_MODE=disabled
# REGISTRATION_CODE=ERSETZE_MICH_code_z_b_xyz123abc

# ── E-Mail-Versand (optional, Setup-Guide: docs/REGISTRATION.md) ──
# Aktiviert E-Mail-Verifizierung bei der Registrierung (E-Mail wird Pflicht,
# Account erst nach Klick auf Bestätigungslink aktiv) sowie Passwort-Reset
# („Passwort vergessen?", Link 60 min gültig). Ohne SMTP_HOST: Registrierung
# wie bisher ohne Verifizierung, Passwort-Reset deaktiviert.
# SMTP_HOST=smtp.example.org
# SMTP_PORT=587                      # 587 = STARTTLS (Default), 465 = SMTPS
# SMTP_SECURE=false                  # true nur für Port 465 (SMTPS)
# SMTP_USER=wachplan@example.org
# SMTP_PASS=ERSETZE_MICH_smtp_passwort
# MAIL_FROM=wachplan@example.org     # Absender (Default: SMTP_USER)

# Öffentliche Basis-URL der App – wird für Links in E-Mails verwendet.
# PFLICHT sobald SMTP konfiguriert ist, sonst zeigen Links auf localhost!
# APP_BASE_URL=https://wachplan.example.org

# ── Bot-Schutz: Google reCAPTCHA v3 (optional) ───────────────
# Schützt Registrierung + Passwort-Reset-Anfrage. Keys erstellen unter
# https://www.google.com/recaptcha/admin (Typ: v3). Beide Keys setzen oder
# beide weglassen (Server validiert das beim Start).
# RECAPTCHA_SITE_KEY=ERSETZE_MICH_site_key
# RECAPTCHA_SECRET_KEY=ERSETZE_MICH_secret_key
# RECAPTCHA_MIN_SCORE=0.5            # 0.0–1.0, Default 0.5 (höher = strenger)

# ── Datenbank (optional) ────────────────────────────────────
# Standard: /app/data/wachplan.db (Docker) bzw. ./data/wachplan.db (lokal).
# DATABASE_PATH=/app/data/wachplan.db

# ── Plan Retention & Cleanup (DSGVO Art. 5 Abs. 1 e) ─────────
# Automatische Löschung inaktiver Pläne nach X Tagen.
# PLAN_RETENTION_DAYS=90 – Pläne werden nach 90 Tagen Inaktivität markiert und später gelöscht
# Default: 90 Tage, disabled wenn nicht gesetzt oder ≤0
# PLAN_RETENTION_DAYS=90
