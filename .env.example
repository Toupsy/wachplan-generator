# Environment Configuration für DLRG Wachplan-Generator
# Kopiere diese Datei zu .env und fülle die Werte aus

# Node Environment
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Encryption & Security (WICHTIG: Generiere neue Werte für Production!)
# Verwende: openssl rand -base64 32 für MASTER_SECRET
# Verwende: openssl rand -base64 16 für SALT
# Verwende: openssl rand -base64 32 für SESSION_SECRET

MASTER_SECRET=ERSETZE_MICH_MIT_OPENSSL_RAND_BASE64_32
SALT=ERSETZE_MICH_MIT_OPENSSL_RAND_BASE64_16
SESSION_SECRET=ERSETZE_MICH_MIT_OPENSSL_RAND_BASE64_32

# Database (wird automatisch erstellt)
DATABASE_PATH=/app/data/wachplan.db
