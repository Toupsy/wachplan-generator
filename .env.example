# ============================================================
# DLRG Wachplan-Generator – Beispiel-Umgebung
# ------------------------------------------------------------
# Diese Datei nach `.env` kopieren und Werte anpassen:
#   cp .env.example .env
# `.env` ist in .gitignore und darf NIEMALS echte Secrets ins
# Repo committen. Sichere Zufallswerte z. B. mit:
#   openssl rand -hex 32
# ============================================================

# --- PFLICHT (geprüft von validateEnv() in server/db/init.js) ---
# Verschlüsselung der Pläne (AES-256-GCM). Min. 32 Zeichen.
MASTER_SECRET=CHANGE_ME_min_32_chars_random_secret_value
# PBKDF2-Salt für Key-Ableitung. Min. 16 Zeichen.
SALT=CHANGE_ME_min_16_chars
# Signierung der Session-Cookies. Min. 16 Zeichen.
SESSION_SECRET=CHANGE_ME_min_16_chars

# --- Server / Netzwerk ---
# Haupt-App (server/server.js)
PORT=3000
HOST=0.0.0.0
# Admin-Panel: gesetzt = eingebettet in den Hauptprozess (empfohlen).
ADMIN_PORT=3001
# 0 = klassischer Zwei-Prozess-Betrieb (nur mit GETRENNTER DB!). Sonst eingebettet.
RUN_EMBEDDED_ADMIN=1
# Reverse-Proxy: Anzahl vertrauenswürdiger Proxies oder true/false.
TRUST_PROXY=1
# 'production' aktiviert sichere Cookies/Header.
NODE_ENV=development
# Erzwingt Secure-Cookies unabhängig von NODE_ENV (true/false).
# COOKIE_SECURE=

# --- Datenbank (SQLite) ---
# Pfad zur DB-Datei (Default: ./data/wachplan.db). Journal-Modus = DELETE (NIE WAL!).
# DATABASE_PATH=/app/data/wachplan.db
# SESSION_DB_PATH=
DB_BUSY_TIMEOUT_MS=30000
# DB_INTEGRITY_RETRIES=6
# DB_INIT_LOCK_TIMEOUT_MS=60000
# DB_INIT_LOCK_STALE_MS=120000
# DB_AUDIT_RETRIES=5
# Bei Korruption hart abbrechen statt Recovery-Hinweis (1 = an).
# DB_ALLOW_CORRUPT_START=
# Session-Auto-Heal abschalten (1 = aus).
# DB_NO_SESSION_AUTOHEAL=

# --- Sessions ---
# SESSION_STORE_RETRIES=
# SESSION_TOUCH_WRITES=

# --- Admin-Auto-Seed (nur beim ersten Start, wenn noch kein Admin existiert) ---
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=CHANGE_ME_min_10_chars

# --- Registrierung ---
# disabled | open | code  (Default: disabled)
REGISTRATION_MODE=disabled
# Pflicht, wenn REGISTRATION_MODE=code:
# REGISTRATION_CODE=

# --- Audit-Log ---
# AUDIT_PLAN_UPDATE_WINDOW_MIN=10
# AUDIT_PLAN_UPDATE_RETENTION_DAYS=30

# --- DSGVO Plan-Retention (Tage; 0 = aus) ---
PLAN_RETENTION_DAYS=0

# --- E-Mail (optional; aktiviert Pflicht-Verifizierung bei Registrierung) ---
# MAIL_TRANSPORT=smtp        # 'outbox' für Tests (kein echter Versand)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=
# Öffentliche URL für Links in E-Mails (sonst zeigen sie auf localhost).
# APP_BASE_URL=https://wachplan.example.org

# --- reCAPTCHA v3 (optional; beide Keys oder keiner) ---
# RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=
# RECAPTCHA_MIN_SCORE=0.5
